# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# JWT secret — change this to a long random string in production
JWT_SECRET=rolescene-change-this-secret-in-production

# ── Admin registration ────────────────────────────────────────────────────────
# Set ADMIN_CODE to a secret string.  When a user registers with this code
# in the "Admin registration code" field, their account is created as role=admin.
# Leave blank (or unset) to disable admin self-registration.
#
# Example:
#   ADMIN_CODE=my-super-secret-admin-key-2025
#
ADMIN_CODE=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file is auto-created at rolescene.db (project root).
# No additional config needed.

# ── Client ────────────────────────────────────────────────────────────────────
# Vite dev server runs on 5173 by default.
# The server CORS whitelist already allows http://localhost:5173
# All API calls use relative paths — Vite proxies /api → localhost:3001
